# Binary assets — distributed via GitHub Releases, not committed to git.
# Keep these files locally for testing but never push them: each release
# tag (cockpit-pfd-v0.1, setup-firmware-v0.1, etc.) carries its asset.

# Tier 1 setup assets
nano25/setup/firmware/*.jic
nano25/setup/firmware/*.zip
nano25/setup/sdcard/*.img
nano25/setup/sdcard/*.img.gz

# Tier 2 demo binaries
nano25/catalog/*/*.elf

# Common build / OS artifacts
.DS_Store
Thumbs.db
